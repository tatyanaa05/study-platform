# API
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Database (PostgreSQL)
# If you changed the forwarded port in docker-compose (e.g., 5433:5432), update the port here too
DATABASE_URL="postgresql://study:study_password@localhost:5432/study_db?schema=public"

# Auth (JWT)
# Replace with long random strings in your real .env (do NOT commit real secrets)
JWT_SECRET="replace_me_with_long_random_string"
JWT_REFRESH_SECRET="replace_me_with_another_long_random_string"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="7d"
BCRYPT_SALT_ROUNDS=10
